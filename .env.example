# ===========================================
# ReFine-Lab Environment Variables
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ===========================================

# HuggingFace (required for gated models like LLaMA)
HF_TOKEN=hf_your_token_here

# Weights & Biases (optional, for experiment tracking)
WANDB_API_KEY=your_wandb_key_here
WANDB_PROJECT=rv-grpo

# Groq (recommended for preference generation — free tier, Llama 3.3 70B)
GROQ_API_KEY=gsk_your_key_here

# Cerebras (alternative — free tier, Llama 3.3 70B, fastest inference)
CEREBRAS_API_KEY=your_key_here

# OpenAI (optional, for preference generation & LLM-judge eval)
OPENAI_API_KEY=sk-your_key_here

# Anthropic (optional, for preference generation)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Together AI (optional, alternative for preference generation)
TOGETHER_API_KEY=your_key_here
